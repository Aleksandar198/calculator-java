import org.testng.annotations.Test;
import org.testng.Assert;

import java.util.ArrayList;
import java.util.Arrays;
import java.util.List;

public class TestCalculator {

    @Test
    public void testCalculateAddition() {

        List<Float> nums = new ArrayList<>(Arrays.asList(4.0f, 5.0f));
        List<String> operation = new ArrayList<>(Arrays.asList("+"));
        Calculator.Calculate(nums, operation);
        Assert.assertEquals(Calculator.finalResult, 9.0f);
    }

    @Test
    public void testCalculateSubstraction() {

        List<Float> nums = new ArrayList<>(Arrays.asList(25.0f, 5.0f));
        List<String> operation = new ArrayList<>(Arrays.asList("-"));
        Calculator.Calculate(nums, operation);
        Assert.assertEquals(Calculator.finalResult, 20.0f);


    }
    @Test
    public void testCalculateMultiplication() {
        List<Float> nums = new ArrayList<>(Arrays.asList(4.0f, 5.0f));
        List<String> operation = new ArrayList<>(Arrays.asList("*"));
        Calculator.Calculate(nums, operation);
        Assert.assertEquals(Calculator.finalResult, 20.0f);

    }

    @Test
    public void testCalculateDivision() {
        List<Float> nums = new ArrayList<>(Arrays.asList(20.0f, 5.0f));
        List<String> operation = new ArrayList<>(Arrays.asList("/"));
        Calculator.Calculate(nums, operation);
        Assert.assertEquals(Calculator.finalResult, 4.0f);
    }

}




